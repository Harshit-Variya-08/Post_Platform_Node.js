<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>

    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <!-- Logout button -->
        <div class="w-full flex justify-start mb-2">
            <a href="/allPosts" class="bg-blue-500 shadow-lg rounded-md px-3 py-1  ">All Posts</a>
        </div>
        <div class="w-full flex justify-end">
            <a href="/logout" class="bg-red-500 shadow-lg rounded-md px-3 py-1  ">Log-out</a>
        </div>
        <!-- Main Heading with Username  -->
        <h1 class="block my-2 font-bold ">Hello ,<%= user.name %> 👋 </h1>
        <br>
        <!--  Form for creating post -->
        <h5 class="mb-2">You can create a post </h5>
        <form action="/post" method="post">
            <textarea name="content" required
                class="w-1/3 p-3 block resize-none bg-transparent border-2 border-zinc-400 rounded-lg"
                placeholder="What's in your mind ?"></textarea>
            <input type="submit" value="Create a Post" class="block p-2  mt-2 w-30 rounded bg-green-700">
        </form>

        <!-- Showing all posts -->
        <div class="posts mt-5">
            <h2 class="text-zinc-200">Your posts : </h2>
            <div class="post_container">
                <!-- single post -->
                 <% user.posts.reverse().forEach((data)=>
                 {
                     %>
                
                <div class="post w-1/3 bg-zinc-800 mb-2 border-2 border-zinc-700 mt-2 rounded-md p-4">
                    <h4 class="text-blue-500 mb-2">@<%= user.name %></h4>
                    <p><%= data.content %></p>
                    <div class="btns mt-5 flex gap-3">
                        <p><%= data.likes.length %></p>
                        <a href="/profile/like/<%= data.id %>" class="text-blue-500"><%= data.likes.includes(user._id) ? "Unlike" : "Like" %> </a>

                        <a href="/profile/edit/<%= data.id %>" class="text-red-400">Edit</a>
                    </div>
                </div>
                   <%  }) %>
          
            </div>

        </div>

    </div>


</body>

</html>