<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>

    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
      
        <!--  Form for updating post -->
        <h5 class="mb-2">Edit your post </h5>
        <form action="/profile/edit/<%= post._id %>" method="post">
            <textarea name="content" required
                class="w-1/3 p-3 block resize-none bg-transparent border-2 border-zinc-400 rounded-lg"><%= post.content %></textarea>
            <input type="submit" value="Edit Post" class="block p-2  mt-2 w-30 rounded bg-blue-700">
        </form>

 

    </div>


</body>

</html>